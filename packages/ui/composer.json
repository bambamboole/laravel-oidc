{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "bambamboole/laravel-oidc-ui",
    "description": "Lattice-powered auth UI for the laravel-oidc identity provider",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "oidc", "openid-connect", "auth-ui", "lattice"],
    "authors": [
        {
            "name": "Manuel Christlieb",
            "email": "manuel@christlieb.eu"
        }
    ],
    "require": {
        "php": "^8.4",
        "bambamboole/laravel-oidc-server": "^0.6",
        "laravel/passkeys": "^0.2",
        "laravel/passport": "^13.4",
        "lattice-php/lattice": "^0.24"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.16",
        "mockery/mockery": "^1.6",
        "mrpunyapal/peststan": "^0.2.10",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Bambamboole\\LaravelOidc\\Ui\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bambamboole\\LaravelOidc\\Ui\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "homepage": "https://github.com/bambamboole/laravel-oidc-ui",
    "support": {
        "issues": "https://github.com/bambamboole/laravel-oidc/issues",
        "source": "https://github.com/bambamboole/laravel-oidc-ui"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6-dev"
        },
        "laravel": {
            "providers": [
                "Bambamboole\\LaravelOidc\\Ui\\UiServiceProvider"
            ]
        }
    },
    "scripts": {
        "analyse": "./vendor/bin/phpstan analyse",
        "check": [
            "@test:lint",
            "@analyse",
            "@test"
        ],
        "lint": "./vendor/bin/pint",
        "test:lint": "./vendor/bin/pint --test",
        "test": "./vendor/bin/pest",
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
